#!/usr/bin/env bash

FCKIT_VERSION_STR="0.14.2"
FCKIT_VERSION="0.14.2"

FCKIT_MAJOR_VERSION=0
FCKIT_MINOR_VERSION=14
FCKIT_PATCH_VERSION=2

FCKIT_GIT_SHA1="fd5b1fb059570ee9c49b2d2e4a580a25ad9b4613"

#################################################################
# Commands
#################################################################

usage()
{
  echo "Usage: fckit [--version] [--info] [--git]"
  exit $1
}

version()
{
  echo "0.14.2"
}

print_feature()
{
  if [ -z "$1" ]; then
    echo "OFF"
  elif [[ $1 =~ (true|TRUE|ON|1) ]]; then
    echo "ON"
  else
    echo "OFF"
  fi
}


info()
{
  echo "fckit version (0.14.2), git-sha1 fd5b1fb059570ee9c49b2d2e4a580a25ad9b4613"
  echo ""
  echo "Build:"
  echo "  build type      : MinSizeRel"
  echo "  timestamp       : 20260226140554"
  echo "  op. system      : Darwin-25.3.0 (macosx.64)"
  echo "  processor       : arm64"
  echo "  sources         : /opt/actions-runner/work/_work/python-develop-bundle/python-develop-bundle/src/fckit"
  echo "  c++ compiler    : AppleClang 17.0.0.17000603"
  echo "    flags         :  -pipe -Os -DNDEBUG"
  echo "  fortran compiler: GNU 15.2.0"
  echo "    flags         :  -Os"
  echo ""
  echo "Features:"
  echo "  MPI             : $(print_feature )"
  echo "  final           : $(print_feature 1)"
  echo "  eckit           : $(print_feature 1)"
  echo ""
  echo "Dependencies: "
  if [ -n "1" ]; then
  echo "  eckit version (2.0.1), git-sha1 $(short_gitsha1 4deb67e8267f7d31edc049b816e84eeb904ff61f)"
  else
  echo "  None"
  fi
}

gitsha1()
{
  echo "fd5b1fb059570ee9c49b2d2e4a580a25ad9b4613"
}

short_gitsha1()
{
  if [ -z "$1" ]; then
    echo "unknown"
  else
    echo $1 | head -c 13
  fi
}

#################################################################
# Parse command-line
#################################################################

if test $# -eq 0; then
    usage 1
fi

while test $# -gt 0; do

    # Split --option=value in $opt="--option" and $val="value"

    opt=""
    val=""

    case "$1" in
    --*=*)
      opt=`echo "$1" | sed 's/=.*//'`
      val=`echo "$1" | sed 's/--[_a-zA-Z0-9]*=//'`
      ;;
    --*)
      opt=$1
      ;;
    *)
      break
      ;;
    esac

    # Parse options
    case "$opt" in
      --version)
        version
        ;;
      --git)
        gitsha1
          ;;
      --info)
        info
        ;;
      --)
        shift
        break
        ;;
      *)
        echo "unknown option: $opt"
        usage 1
        ;;
    esac
    shift
done
