# This pkg-config file is generated by ecbuild_pkgconfig()
# with template ecbuild/cmake/pkg-config.pc.in

git_tag=4deb67e8267f7d31edc049b816e84eeb904ff61f

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
bindir=${prefix}/bin
fmoddir=${prefix}/include

CC=/usr/bin/cc
CXX=/usr/bin/c++
FC=

libs=-Wl,-rpath,${libdir} -L${libdir} -leckit_sql

libs_private=-Wl,-rpath,${libdir} -L${libdir} -leckit -Wl,-rpath,/opt/homebrew/lib -L/opt/homebrew/lib -llz4 -Wl,-rpath,/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib -L/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib -lbz2 -lcurl -l$<0:libaec::aec -lm

cflags=-I${includedir} -I/tmp/eckit/target/eckit/include -I/tmp/eckit/target/eckit/include/eckit/sql

#====================================================================
Name: eckit_sql
Description: ECMWF C++ Toolkit - eckit_sql library
URL: https://software.ecmwf.int/wiki/display/ECKIT/ecKit
Version: 2.0.1
Libs: ${libs}
Libs.private: ${libs_private}
Requires: 
Requires.private: 
Cflags: ${cflags}
#====================================================================
